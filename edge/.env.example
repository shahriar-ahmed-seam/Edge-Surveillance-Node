# ---- Edge Agent configuration ----
# Required variables have no default and will cause fail-fast on startup if missing.

# Node identity (REQUIRED)
NODE_ID=node-dev-001
NODE_NAME=Front Door Camera

# Camera (OpenCV) -- index for a USB cam, path for a file/RTSP URL
CAMERA_SOURCE=0
TARGET_FPS=12
CAMERA_FAILURE_THRESHOLD=10          # consecutive read failures before degraded
CAMERA_RECOVERY_READS=15             # consecutive good reads required to clear degraded
CAMERA_BACKOFF_BASE_S=1.0
CAMERA_BACKOFF_MAX_S=30.0

# Model / inference (REQUIRED: MODEL_PATH)
MODEL_PATH=./models/detector.int8.onnx
MODEL_LABELS_PATH=./models/labels.txt
MODEL_INPUT_SIZE=320
CONFIDENCE_THRESHOLD=0.45
NMS_IOU_THRESHOLD=0.45
INFERENCE_MAX_RECOVERY_ATTEMPTS=5

# Events / snapshots
EVENT_DEBOUNCE_SECONDS=5             # per-class cooldown
SNAPSHOT_ENABLED=true
SNAPSHOT_MAX_BYTES=51200             # 50 KB
SNAPSHOT_MIN_JPEG_QUALITY=30

# MQTT (REQUIRED: MQTT_HOST, MQTT_USERNAME, MQTT_PASSWORD)
MQTT_HOST=localhost
MQTT_PORT=8883
MQTT_USERNAME=edge
MQTT_PASSWORD=change-me
MQTT_USE_TLS=true
MQTT_CA_CERT=                        # optional path to CA bundle
MQTT_QOS=1
OUTBOX_MAX_SIZE=1000

# Heartbeat
HEARTBEAT_INTERVAL_S=10

# Logging
LOG_LEVEL=INFO
