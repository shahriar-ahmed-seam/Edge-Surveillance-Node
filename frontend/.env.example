# ---- Frontend (Next.js on Vercel) configuration ----

# API + WebSocket endpoints (REQUIRED)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws/events

# Branding assets (OPTIONAL). When unset, professional placeholders render.
# Provide URLs or /public paths once assets are supplied.
NEXT_PUBLIC_ASSET_LOGO=
NEXT_PUBLIC_ASSET_WORDMARK=
NEXT_PUBLIC_ASSET_HERO=
NEXT_PUBLIC_ASSET_FAVICON=
NEXT_PUBLIC_BRAND_NAME=Edge-Surveillance-Node
NEXT_PUBLIC_BRAND_ACCENT=#22D3EE
