# ---- Backend (FastAPI on Render) configuration ----
# Required variables fail-fast on startup if missing.

# Database (REQUIRED)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/edge

# JWT / auth (REQUIRED: JWT_SECRET)
JWT_SECRET=change-me-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_LIFETIME_HOURS=12                # hard-capped at 24; >24 is rejected at startup

# MQTT broker subscription (REQUIRED: MQTT_HOST, MQTT_USERNAME, MQTT_PASSWORD)
MQTT_HOST=localhost
MQTT_PORT=8883
MQTT_USERNAME=ingestion
MQTT_PASSWORD=change-me
MQTT_USE_TLS=true
MQTT_CA_CERT=
MQTT_TOPIC_EVENTS=nodes/+/events
MQTT_TOPIC_HEARTBEAT=nodes/+/heartbeat

# Object storage (S3-compatible). For local dev use MinIO.
STORAGE_BACKEND=s3                   # s3 | disk
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=snapshots
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
SIGNED_URL_TTL_SECONDS=300
DISK_STORAGE_PATH=./data/snapshots   # used when STORAGE_BACKEND=disk

# Fleet
NODE_OFFLINE_TIMEOUT_S=30
OFFLINE_CHECK_INTERVAL_S=5

# Server
HOST=0.0.0.0
PORT=8000
CORS_ALLOW_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
